generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "darwin", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WorkSession {
  id         Int            @id @default(autoincrement())
  date       String         // YYYY-MM-DD（日別クエリ用）
  clockInAt  String         @map("clock_in_at") // ISO8601
  clockOutAt String?        @map("clock_out_at") // ISO8601（null=勤務中）
  note       String?
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  breaks     BreakSession[]

  @@index([date], map: "idx_work_sessions_date")
  @@index([clockInAt(sort: Desc)], map: "idx_work_sessions_clock_in")
  @@map("work_sessions")
}

model BreakSession {
  id            Int         @id @default(autoincrement())
  workSessionId Int         @map("work_session_id")
  startAt       String      @map("start_at") // ISO8601
  endAt         String?     @map("end_at") // ISO8601（null=休憩中）
  note          String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  workSession   WorkSession @relation(fields: [workSessionId], references: [id], onDelete: Cascade)

  @@index([workSessionId], map: "idx_break_sessions_work_session_id")
  @@map("break_sessions")
}
